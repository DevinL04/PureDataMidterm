#X text 30 365 VOICES (one abstraction per game event \, each with its own per-voice volume slider below);
#X text 100 395 PICKUP - Pulse 1 + Pulse 2;
#X text 100 415 trig: /unity/trigger;
#X obj 130 470 pickup;
#X obj 100 425 hsl 128 15 0 1 0 0 empty empty empty -2 -8 0 10 -262144 -1 -1 0 1;
#X obj 230 445 pack f 20;
#X obj 230 480 line~;
#X obj 130 510 *~;
#X text 350 395 WALL - Noise;
#X text 350 415 trig: /unity/colwall;
