#X obj 870 555 *~;
#X obj 870 600 dac~;
#X text 30 660 VOICE PARAMETERS (control buses - move sliders to retune voices in real-time);
#X text 30 685 Pulse 1 duty cycle (0-1);
#X obj 30 705 hsl 200 15 0 1 0 1 pickup_duty1 empty empty -2 -8 0 10 -262144 -1 -1 0.5 1;
#X text 30 730 Pulse 2 duty cycle (0-1);
#X obj 30 750 hsl 200 15 0 1 0 1 pickup_duty2 empty empty -2 -8 0 10 -262144 -1 -1 0.25 1;
#X text 280 685 Pickup pitch sweep amount (semitones \, -12 to 12);
#X obj 280 705 hsl 200 15 -12 12 0 1 pickup_sweep_amt empty empty -2 -8 0 10 -262144 -1 -1 0 1;
#X text 280 730 Pickup pitch sweep time (ms \, 10-200);
#X obj 280 750 hsl 200 15 10 200 0 1 pickup_sweep_time empty empty -2 -8 0 10 -262144 -1 -1 30 1;
#X text 530 685 Wall low-pass cutoff (Hz \, 200-8000);
#X obj 530 705 hsl 200 15 200 8000 0 1 wall_lp_cutoff empty empty -2 -8 0 10 -262144 -1 -1 1500 1;
